# Copy to .env for local use, or set these in your host's dashboard for production.

# Admin login (used ONLY the first time the database is created, to seed the admin user)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password

# Secret used to sign login tokens. Use a long random string in production.
JWT_SECRET=replace-with-a-long-random-string

# Where the database + uploaded logos are stored. In production point these at a
# persistent volume so data survives restarts/redeploys.
DB_PATH=/data/data.db
UPLOAD_DIR=/data/uploads

# Port (most hosts set this automatically; defaults to 3001 locally)
# PORT=3001

# --- OTP via Twilio Verify (optional) ---
# When all three are set, sign-in codes are sent for real via Twilio (and the code
# is NO LONGER shown on screen). Leave blank to stay in dev mode.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OTP_CHANNEL=sms                # sms | whatsapp | call
# DEFAULT_COUNTRY_CODE=966       # used to turn 05xxxxxxxx into +9665xxxxxxxx
