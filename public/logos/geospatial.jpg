 || window.location.origin.replace(':8080', ':8000');\\n               const lang   = params.get('lang') || 'ar';\\n               const token  = params.get('token') || undefined;\\n\\n               (function tryMount(attempts) {\\n                 if (window.ChatbotWidget) {\\n                   window.ChatbotWidget.mountChatbot({ apiUrl, lang, token });\\n                 } else if (attempts \u003c 100) {\\n                   setTimeout(function () { tryMount(attempts + 1); }, 100);\\n                 } else {\\n                   console.warn(\\\"ChatbotWidget failed to load after 10s\\\");\\n                 }\\n               })(0);\\n              \"}]]]}]}]]}]\n"])</script><script>self.__next_f.push([1,"14:[[\"$\",\"meta\",\"0\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}],[\"$\",\"meta\",\"1\",{\"charSet\":\"utf-8\"}],[\"$\",\"title\",\"2\",{\"children\":\"المنصة الوطنية\"}],[\"$\",\"meta\",\"3\",{\"name\":\"description\",\"content\":\"البوابة الوطنية للمعلومات والخدمات الحكومية الرقمية كافة في المملكة العربية السعودية والمصدر المتخصص في التسهيل على المواطنين والمقيمين ورجال الأعمال والزوّار للبحث والوصول بكل سهولة ويسر \"}],[\"$\",\"meta\",\"4\",{\"name\":\"application-name\",\"content\":\"GOV.SA\"}],[\"$\",\"link\",\"5\",{\"rel\":\"manifest\",\"href\":\"/manifest.json\",\"crossOrigin\":\"use-credentials\"}],[\"$\",\"meta\",\"6\",{\"name\":\"keywords\",\"content\":\"المنصة، الوطنية, منصه وطنيه, منصة وطنية, المنصة الوطنية, الخدمات الحكومية, خدمات حكومية, خدمات حكوميه, دليل الخدمات, دليل الجهات الحكومية,  المنصة الوطنية البوابة الوطنية المنصة الموحدة الوطنية البوابة الموحدة الوطنية المنصة الوطنية الموحدة البوابة الوطنية الموحدة المنصة الحكومية السعودية منصة الحكومة السعودية\"}],[\"$\",\"meta\",\"7\",{\"name\":\"apple-itunes-app\",\"content\":\"app-id=1540772140, app-argument=https://my.gov.sa/ar/files/agency_files/u5pqr13q67biksqpw0jayx6k6b0dabuj.JPG\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:title\",\"content\":\"المنصة الو