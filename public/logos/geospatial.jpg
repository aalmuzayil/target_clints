4aec8.js\",\"1203\",\"static/chunks/app/%5Blocale%5D/layout-4a9eab19f2d48634.js\"],\"default\"]\n24:I[92222,[\"7382\",\"static/chunks/7382-e0bda117361ddd79.js\",\"6933\",\"static/chunks/6933-dea48cfebe244af7.js\",\"3145\",\"static/chunks/3145-1b7c1d3f59859968.js\",\"4353\",\"static/chunks/4353-703fd9b81be81ebc.js\",\"6816\",\"static/chunks/app/%5Blocale%5D/error-9f8aad03e3748d42.js\"],\"default\"]\n25:I[53893,[\"7382\",\"static/chunks/7382-e0bda117361ddd79.js\",\"6933\",\"static/chunks/6933-dea48cfebe244af7.js\",\"3145\",\"static/chunks/3145-1b7c1d3f59859968.js\",\"7381\",\"static/chunks/7381-1814734db52f44e5.js\",\"8382\",\"static/chunks/8382-9561e31c4534aec8.js\",\"1203\",\"static/chunks/app/%5Blocale%5D/layout-4a9eab19f2d48634.js\"],\"default\"]\n26:I[98318,[\"7382\",\"static/chunks/7382-e0bda117361ddd79.js\",\"6933\",\"static/chunks/6933-dea48cfebe244af7.js\",\"3145\",\"static/chunks/3145-1b7c1d3f59859968.js\",\"7381\",\"static/chunks/7381-1814734db52f44e5.js\",\"8382\",\"static/chunks/8382-9561e31c4534aec8.js\",\"1203\",\"static/chunks/app/%5Blocale%5D/layout-4a9eab19f2d48634.js\"],\"default\"]\n22:Ta8a,"])</script><script>self.__next_f.push([1,"\u003cp\u003eيقدم دليل الخدمات في المنصة الوطنية كافة الخدمات الحكومية المقدمة للمواطنين والمقيمين والزوّار ورجال الأعمال، مما يسهّل الوصول إلى المعلومات والخدمات الحكومية عبر تجربة رقمية متكاملة.\u0026nbsp;\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eكيف تستخدم خدمات المنصة الوطنية GOV.SA؟\u003c/strong\u003e\u003c/p\u003e\u003cp\u003e\u0026nbsp;تمكن المنصة الوطنية المواطنين والمقيمين والزوار من استعراض الخدمات وصفحات المحتوى التي تهمهم والاستفادة منها بأسلوب تصفح مبسط وسلس يمكن لمعظم المستخدمين توقعه والتعامل معه، كما توفر أداة تفاعلية تقود المستخدم في رحلة افتراضية عبر المنصة لتوضيح أهم العناصر المتوفرة وكيفية الاستفادة منها، تتوفر هذه الأداة في صفحة \u003ca href=\"https://my.gov.sa/ar/about\"\u003eما هي المنصة الوطنية GOV.SA\u003c/a\u003e.\u0026nbsp;\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eتطبيق الخدمات الحكومية \"توكلنا خدمات\"\u003c/strong\u003e\u003cbr\u003eتتبع حكومة المملكة العربية السعودية نهجاً يهدف إلى توفير كافة الخدمات الحكومية في مكان واحد لتسهيل العثور عليها والاستفادة منها، حيث لا يقتصر هذا على البوابة الوطنية بل يمتد ليشمل تطبيقات الجوال، ومن هذا المنطلق تم تطوير تطبيق \"\u003ca href=\"https://my.gov.sa/ar/govApps?title=توكلنا+خدمات\u0026amp;highlight=توكلنا\"\u003eتوكلنا خدمات\u003c/a\u003e\" الذي يوفر باقة كبيرة من الخدمات الحكومية وتتم إضافة المزيد من الخدمات إليه بشكل مضطرد من قبل مختلف الجهات الحكومية والوزارات.\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eالأسئلة الشائعة\u003c/strong\u003e\u003cbr\u003eتمكن المنصة الوطنية زوارها والمستفيدين منها من الاطلاع على إجابات أهم الأسئلة والاستفسارات المتعلقة بكيفية الاستفادة من المنصة وخدماتها مثل ما هي قنوات تقديم الخدمة؟، وهل يلزم التسجيل في المنصة للوصول إلى المعلومات والخدمات التي تقدمها؟، وكيف يمكنني الوصول للخدمات الإلكترونية في المنصة؟، وغيرها الكثير عبر صفحة \u003ca href=\"https://my.gov.sa/ar/faqs\"\u003eالأسئلة الشائعة\u003c/a\u003e.\u003c/p\u003e"])</script><script>self.__next_f.push([1,"1e:[\"$\",\"$L20\",null,{\"locale\":\"ar\",\"now\":\"$D2026-05-25T13:59:24.656Z\",\"timeZone\":\"UTC\",\"messages\":{\"seo\":{\"title\":\"المنصة الوطنية للخدمات الحكومية\",\"description\":\".البوابة الوطنية للمملكة العربية السعودية للخدمات والمعلومات الحكومية المنصة الوطنية توفر لك الدخول الموحد لجميع الخدمات الحكومية شاملةً الوزارات والهيئات والمؤسسات الحكومية\",\"unified-national-file\":{\"title\":\"الملف الوطني الموحد\",\"description\":\"الملف الوطني الموحد يقدم لك جميع خدماتك الحكومية في مكان واحد. إدارة هويتك الرقمية، الخدمات الشخصية، والوصول السهل لجميع الخدمات الحكومية في المملكة العربية السعودية.\",\"keywords\":\"الملف الوطني الموحد، الخدمات الحكومية، الهوية الرقمية، المملكة العربية السعودية، منصة GOV.SA، الخدمات الإلكترونية\"},\"user-profile\":{\"title\":\"الملف الشخصي\",\"description\":\"إدارة ملفك الشخصي في الملف الوطني الموحد. عرض وتحديث معلوماتك الشخصية، الخدمات المفضلة، وتتبع طلباتك الحكومية في المملكة العربية السعودية.\",\"keywords\":\"الملف الشخصي، الملف الوطني الموحد، المعلومات الشخصية، الخدمات المفضلة، المملكة العربية السعودية، منصة GOV.SA\"},\"user-complaints\":{\"title\":\"بلاغاتي الرقمية\",\"description\":\"إدارة وتتبع شكاوى المستخدمين في منصة GOV.SA. تقديم شكاوى جديدة، متابعة حالة الشكاوى، والتفاعل مع الجهات الحكومية في المملكة العربية السعودية.\",\"keywords\":\"شكاوى المستخدمين، الشكاوى الحكومية، متابعة الشكاوى، المملكة العربية السعودية، منصة GOV.SA، الخدمات الحكومية\"},\"new-complaint\":{\"title\":\"تقديم شكوى جديدة\",\"description\":\"تقديم شكوى جديدة للجهات الحكومية في المملكة العربية السعودية. املأ نموذج الشكوى بسهولة ووضوح، واختر الجهة الحكومية المناسبة، وتتبع حالة شكواك.\",\"keywords\":\"تقديم شكوى، شكوى جديدة، الشكاوى الحكومية، المملكة العربية السعودية، منصة GOV.SA، الخدمات الحكومية\"},\"new-digital-transformation\":{\"title\":\"خدمة الإبلاغ عن خدمة ورقية جديد\",\"description\":\"تقديم طلب خدمة الإبلاغ عن خدمة ورقية جديد للجهات الحكومية في المملكة العربية السعودية. املأ نموذج الطلب بسهولة، واختر الجهة الحكومية المناسبة، وتتبع حالة طلبك للتحول الرقمي.\",\"keywords\":\"طلب خدمة الإبلاغ عن خدمة ورقية، الطلبات الحكومية، المملكة العربية السعودية، منصة GOV.SA، الخدمات الرقمية\"},\"new-suggestion\":{\"title\":\"اقتراح تطوير جديد\",\"description\":\"اقتراح تطوير جديد لتحسين الخدمات الحكومية في المملكة العربية السعودية. شارك أفكارك واقتراحاتك لتطوير الخدمات الحكومية، واختر الجهة الحكومية المناسبة، وتتبع حالة اقتراحك.\",\"keywords\":\"اقتراح تطوير، اقتراح جديد، تحسين الخدمات الحكومية، المملكة العربية السعودية، منصة GOV.SA، المشاركة المجتمعية\"}},\"home\":\"الرئيسية\",\"features\":\"الميزات\",\"learn\":\"تعلم\",\"about\":\"حول\",\"pricing\":\"التسعير\",\"support\":\"الدعم\",\"documentation\":\"التوثيق\",\"resources\":\"الموارد\",\"community\":\"المجتمع\",\"blog\":\"المدونة\",\"faq\":\"الأسئلة الشائعة\",\"demo\":\"احجز عرضاً توضيحياً\",\"forums\":\"المنتديات\",\"rss\":\"RSS\",\"terms\":\"شروط الاستخدام\",\"sitemap\":\"خريطة الموقع\",\"map\":\"الموقع : {map}\",\"reports-year\":\"تقرير لعام\",\"view-the-map\":\"الاطلاع على الموقع\",\"participate-in-the-event\":\"مشاركة الفعالية\",\"privacy\":\"سياسة الخصوصية\",\"contact_us\":\"تواصل معنا\",\"accessibility_tools\":\"أدوات إتاحة الوصول\",\"rights_reserved\":\"© 2023 جميع الحقوق محفوظة لـ منصة GOV.SA\",\"developed_by\":\"تطوير وتشغيل هيئة الحكومة الرقمية\",\"overview\":\"نظرة عامة\",\"about_platform\":\"عن المنصة الوطنية\",\"about_saudi\":\"عن المملكة العربية السعودية\",\"know-the-kingdom\":\"تعرف علي المملكة\",\"gov-type\":\"نظام الحكم\",\"new_visitor\":\"زائر جديد\",\"news\":\"الأخبار\",\"desc_news\":\"استكشف كل الأخبار ذات الصلة والأحداث البارزة\",\"events\":\"الفعاليات\",\"important_links\":\"روابط مهمة\",\"reports_data\":\"التقارير والبيانات\",\"statistics_indicators\":\"إحصائيات ومؤشرات المنصة\",\"open_data\":\"البيانات المفتوحة\",\"sustainable_development\":\"التنمية المستدامة\",\"gulf_platforms\":\"منصات الحكومات الإلكترونية الخليجية\",\"support_help\":\"الدعم والمساعدة\",\"tafaul_center\":\"مركز تفاعل للمستفيدين من المنصة\",\"digital_report\":\"بلاغ رقمي\",\"service_channels\":\"قنوات تقديم الخدمة\",\"report_corruption\":\"الإبلاغ عن فساد\",\"search\":\"البحث\",\"search-advanced\":\"البحث المتقدم\",\"login\":\"تسجيل الدخول\",\"logout\":\"تسجيل خروج\",\"customer-services\":\"الدعم والمساعدة\",\"emergency-contact\":\"أرقام التواصل في حالات الطوارئ\",\"social-media\":\"التواصل الاجتماعي\",\"search-engine\":\"نتائج البحث\",\"participation-survey\":\"استبيان المشاركة في فعاليات الجهات الحكومية\",\"experience\":\"تجارب الحياة\",\"agency\":\"الجهات\",\"ar\":\"عربي\",\"hajj\":\"الحج والعمرة\",\"faqs\":\"الأسئلة الشائعة\",\"no-data\":\"لاتوجد بيانات\",\"no-location\":\"لايوجد موقع\",\"organizer\":\"المنظم\",\"register-event\":\"التسجيل في الفعالية\",\"steps\":\"الخطوات\",\"prerequisites\":\"المتطلبات\",\"customer_support\":\"دعم العملاء\",\"required-documents\":\"المستندات المطلوبة\",\"content\":\"محتوى\",\"Share-page\":\"مشاركة الصفحة\",\"summer\":\"الصيف\",\"winter\":\"الشتاء\",\"autumn\":\"الخريف\",\"spring\":\"الربيع\",\"location\":\"الموقع\",\"kingdom\":\"ملكي\",\"capital\":\"العاصمة\",\"area\":\"المساحة\",\"regions\":\"عدد المناطق\",\"vital-sectors-title\":\"القطاعات الحيوية بالمملكة\",\"related-news\":\"اخبار ذات صلة\",\"payment_channels\":\"قنوات الدفع\",\"download-user-manual\":\"تحميل دليل المستخدم\",\"related-apps\":\"تطبيقات ذات صلة\",\"related-services\":\"خدمات ذات صلة\",\"related-services-desc\":\"الخدمات التي يبحث عنها معظم المواطنين\",\"show-all\":\"عرض الكل\",\"all\":\"الكل\",\"ksa\":\"المملكة العربية السعودية\",\"follow-official\":\"تــــابع المسؤول علــــى\",\"ways-to-communicate-with-the-authority\":\" طرق التواصل مع الجهة\",\"Services-of-the-Authority\":\" خدمات الجهة\",\"profile\":\"الملف الشخصي\",\"expiryDateGregorian\":\"الهوية الخاصة بك سارية حتى\",\"the-first-responsible\":\"المسؤول الاول\",\"trial-version\":\"نسخة تجريبية\",\"nav\":{\"about_kingdom\":{\"know_kingdom\":\"تعرف على المملكة\",\"systems_policies\":\"الأنظمة واللوائح\",\"government_work\":\"دليل الجهات الحكومية\",\"eGovernment-portals\":\"منصات الحكومات الإلكترونية الخليجية\",\"digital_transformation\":\"التحوّل الرقمي\",\"about_portal\":\"عن المنصة الوطنية GOV.SA\",\"portals-visitors-statistics\":\"إحصاءات أداء البوابة\",\"services_guide\":\"دليل الخدمات\",\"entities-performance-index\":\"مؤشر أداء الجهات\",\"digital_strategy\":\"استراتيجية الحكومة الرقمية 2023-2030\",\"government_plans\":\"الخطط والمبادرات الحكومية\",\"reports_statistics\":\"تقارير وإحصائيات\",\"state_budget\":\"ميزانية الدولة\",\"procurement\":\"المناقصات والمشتريات\",\"payment_channels\":\"قنوات الدفع\",\"education_training\":\"التعليم والتدريب\",\"healthcare\":\"الرعاية الصحية\",\"jobs_recruitment\":\"العمل والتوظيف\",\"social_protection\":\"الحماية الاجتماعية\",\"environment\":\"حماية البيئة\",\"gis_systems\":\"نظم المعلومات الجغرافية\",\"justice_law\":\"العدل والقضاء\",\"logistics_transport\":\"النقل والخدمات اللوجستية\",\"investment\":\"الاستثمار\",\"tourism_visas\":\"التأشيرات والسياحة\",\"hajj_umrah\":\"الحج والعمرة\",\"energy_electricity\":\"الطاقة والكهرباء\",\"sports\":\"الرياضة\",\"industry_mining\":\"الصناعة والثروة المعدنية\",\"municipal_housing\":\"الشؤون البلدية والإسكان\",\"commerce\":\"التجارة\",\"culture\":\"الثقافة\",\"user_complaints\":\"بلاغاتي الرقمية\",\"new_complaint\":\"تقديم شكوى\",\"new_suggetion\":\"اقتراح تطوير\",\"digital_transform_request\":\"تطور رقمي\",\"benificaryReports\":\"تقارير المستفيدين\",\"surveys\":\"الاستطلاعات\",\"nationalDevelopmentPlans\":\"الخطط والمبادرات الوطنية\"}},\"home_hero\":{\"platform_title\":\"المنصة الوطنية GOV.SA\",\"platform_description\":\"المرجع الوطني الاول للمعلومات والخدمات الحكومية الرقمية كافة في المملكة العربية السعودية والمصدر المتخصص في التسهيل على المواطنين والمقيمين ورجال الأعمال والزوّار للبحث والوصول بكل سهولة ويسر.\",\"explore_services\":\"استكشف الخدمات\",\"about_platform\":\"عن المنصة\",\"card_1_title\":\"مخصصة\",\"card_1_description\":\"خدمات مصممة بناءً على احتياجاتك الخاصة ومراحل حياتك المختلفة توفر لك تجربة مثالية وملائمة واستباقية.\",\"card_2_title\":\"موثوقة\",\"card_2_description\":\"مصدر موحد لجميع المعلومات والخدمات الحكومية يضمن لك تجربة فعالة ومريحة مبنية على الدقة والوضوح.\",\"card_3_title\":\"مركزية\",\"card_3_description\":\"واجهة ذات هوية رقمية موحدة تتيح لك الوصول إلى جميع الخدمات الحكومية بسرعة وسهولة تامة من أي مكان وفي أي وقت.\"},\"home_banner\":{\"title_1\":\"العـمق العربـي والإسلامي\",\"subtitle_1\":\"السعودية\",\"description_1\":\"قوة استثمارية رائدة، ومحور ربط القارات الثلاثة\",\"title_2\":\"التحول الوطني\",\"subtitle_2\":\"رؤية الرياض 2030\",\"description_2\":\"قوة استثمارية رائدة، ومحور ربط القارات الثلاثة\",\"learn_more\":\"تعرف أكثر على المملكة\"},\"home_services\":{\"integrated_services\":\"خدمات متكاملة\",\"digital_signature\":\"بصمة رقمية في كل خدمة\",\"description\":\"نظام موحد يتيح لك الوصول إلى كافة الخدمات الحكومية بمرونة وسهولة.\",\"view_all_services\":\"عرض جميع الخدمات\",\"tabs\":{\"business\":\"إدارة وريادة الأعمال\",\"education\":\"التعليم والتدريب\",\"family\":\"المسائل العائلية وأحداث الحياة\",\"health\":\"خدمات الصحة\",\"financial\":\"خدمات مالية\",\"business_desc\":\"وصف مفصل لخدمة الأعمال\",\"education_desc\":\"وصف مفصل لخدمة التعليم\",\"family_desc\":\"وصف مفصل لخدمة العائلة\",\"health_desc\":\"وصف مفصل لخدمة الصحة\",\"financial_desc\":\"وصف مفصل لخدمة المالية\",\"business_tag\":\"وزارة الشؤون الاسلامية\",\"education_tag\":\"وزارة الشؤون الاسلامية\",\"family_tag\":\"وزارة الشؤون الاسلامية\",\"health_tag\":\"وزارة الشؤون الاسلامية\",\"financial_tag\":\"وزارة الشؤون الاسلامية\"}},\"node\":{\"node_desc\":\"إيمانًا من المملكة بأهمية التعليم حرصت على توفير الفرص التعليمية والتدريبية لكافة فئات المجتمع. يعرض هذا القسم جهود المملكة العربية السعودية في تعزيز المعرفة وتنمية المهارات. بما في ذلك برامج التعليم بدءًا من برامج الطفولة المبكرة، والتعليم العام بمراحله، وبرامج التربية الخاصة، والتعليم عن بعد والتعليم الإلكتروني، والصحة والسلامة المدرسية، وبرامج التعليم الجامعي والعالي، والتعليم المهني والتدريب التقني، وفرص التعليم للأجانب. كما يعرض هذا القسم منح الدراسة في الخارج للطلاب السعوديين، وكذلك المنح الداخلية للطلاب السعوديين وغير السعوديين.\"},\"desc_services_guide\":\"وجهة نظر لجميع الخدمات الحكومية\",\"filters_search_placeholder\":\"بحث بإسم الخدمات\",\"filters_search_aria\":\"بحث بإسم الخدمات\",\"search_news\":\"بحث في الاخبار\",\"filters_sort_placeholder\":\"ترتيب بحسب\",\"filters_sort_asc\":\"تصاعدي\",\"filters_sort_desc\":\"تنازلي\",\"categories\":\"الفئات\",\"categories-2\":\"التصنيفات\",\"mostUsedServices\":\"الخدمات الأكثر استخداماً\",\"businessManagement\":\"إدارة وريادة الأعمال\",\"educationAndTraining\":\"التعليم والتدريب\",\"higherEducation\":\"التعليم العالي\",\"saudiUniversities\":\"الجامعات في المملكة العربية السعودية\",\"vocationalTraining\":\"تدريب مهني و تطوير المهارات\",\"familyMatters\":\"المسائل العائلية و أحداث الحياة\",\"childLink1\":\"الرابط الفرعي 1\",\"childLink2\":\"الرابط الفرعي 2\",\"childLink3\":\"الرابط الفرعي 3\",\"nestedParentLink\":\"رابط رئيسي متداخل\",\"desc_systems_policies\":\"عرض جميع الخدمات الحكومية\",\"desc_government_work\":\"يعرض الدليل المعلومات ذات العلاقة بجميع الجهات الحكومية في المملكة العربية السعودية، وتشمل الموقع الإلكتروني للجهة ومعلومات الاتصال وموقعها على الخريطة وحساباتها على مواقع التواصل الاجتماعي، علاوة على بيانات المسؤول الأول بالجهة وأداة التواصل معه. ويمكن عن طريق صفحة الجهة في الدليل الدخول إلى خدماتها الإلكترونية والاستفادة منها.\",\"desc_digital_transformation\":\"لا تعتبر المملكة العربية السعودية مجرد عامل تمكين للتحول الرقمي، بل أنها قدمت أسس جوهرية لتعريف وإعادة تحديد جوهر واجبات الحكومة. وهو أمر لا يمكن الإغفال عنه حيث يشهد العالم في هذه الآونة تتطور التكنولوجيا على نحو ضخم وانتقالها إلى آفاق جديدة. تماشياً مع رؤية 2030، فإن التحول الرقمي للحكومة السعودية يُعد استراتيجية متكاملة وحاسمة وعملية تهدف إلى تمكين وتسريع التحول الحكومي بكفاءة وفعالية. وقد تم تبني هذا التحول من خلال العديد من برامج ومشاريع الحكومة الإلكترونية، مع تمكين ودعم المؤسسات والهيئات الحكومية المختلفة. وهو يهدف بشكل أساسي إلى توفير جميع الخدمات الحكومية رقميًا، وإتاحة الوصول إليها بسهولة. كما تم تصميم استراتيجية التحول وتنفيذها على نحو يحفظ محاذاة الهندسة المعمارية، وليكون مواكبًا للعصر الرقمي، مدعومًا بالمهارات والقدرات والأدوات الرقمية. توفر رؤية 2030 برنامج تحول فعال وجيد التخطيط يُعرف باسم برنامج التحول الوطني، ويهدف إلى تطوير البنية التحتية اللازمة وخلق بيئة تُمكن القطاعات العامة والخاصة وغير الربحية من تحقيق مستهدفات رؤية 2030.\",\"clearChoices\":\"مسح الخيارات\",\"entities\":[\"هيئات\",\"مراكز\",\"كليات\",\"مؤسسات\",\"مجالس\",\"مديريات\",\"دواوين\",\"كليات\",\"كليات\",\"قوات\",\"السفارات الأجنبية\"],\"request-a-fatwa\":\"طلب فتوى\",\"desc-request-a-fatwa\":\"خدمة إلكترونية تقدمها الرئاسة العامة للبحوث العلمية والإفتاء تمكن المستفيدين من الاستفسار عن كافة الفتاوى الدينية والشرعية من خلال تقديم طلب فتوى يتضمن السؤال المراد الإجابة عنه.\",\"desc-portals-visitors-statistics\":\"توفر هذه الصفحة الإحصاءات الإجمالية لمستخدمي البوابة (بدءًا من 1 يناير 2022). تستند الإحصاءات إلى مستخلص من Google Analytics\",\"required_field\":\"الحقل المطلوب\",\"share_feedback\":\"شاركنا رأيك، وساهم بالتحسين\",\"page_rating_desc\":\"هل أعجبك محتوى الصفحة ؟\",\"yes\":\"نعم\",\"no\":\"لا\",\"submit\":\"إرسال\",\"cancel\":\"إلغاء\",\"feedback_thanks\":\"شكراً لتقييمك للصفحة، رأيك يساهم معنا بالتحسين\",\"rating_success\":\"تم إرسال التقييم بنجاح\",\"desc-entities-performance-index\":\"توفر هذه الصفحة الإحصاءات الإجمالية لمستخدمي البوابة (بدءًا من 1 يناير 2022). تستند الإحصاءات إلى مستخلص من Google Analytics\",\"desc-events\":\"رؤية التحديثات الخاصة بك وإدارة جميع إجراءات الخدمات والمواعيد الخاصة بك\",\"desc-reports_data\":\"مساحة مخصصة توفر الوصول لتقارير وبيانات المنصة الوطنية الموحدة، لتمكين المشاركة والاستفادة منها من قبل الجهات المختصة والمستفيدين\",\"card_1_title\":\"البيانات المفتوحة\",\"card_1_description\":\"يتناول هذا القسم استراتيجية وحوكمة وإرشادات البيانات الحكومية المفتوحة في المملكة العربية السعودية.\",\"card_2_title\":\"المشاركة الإلكترونية\",\"card_2_description\":\"لكي تكون جزءًا من عملية صنع القرار ، نتيح لك تقديم أفضل ما لديك ومشاركة آرائك وأفكارك حول القوانين القادمة والمشاريع الاقتصادية والشؤون التنموية.\",\"card_3_title\":\"الخصوصية وحماية البيانات\",\"card_3_description\":\"يعرض هذا القسم للمستخدمين قوانين وسياسات المملكة العربية السعودية لحماية البيانات الشخصية وخصوصية المستخدمين وبياناتهم الحساسة.\",\"card_4_title\":\"تحديث محتوى المنصة الوطنية الموحدة\",\"card_4_description\":\"يُقدّم فريق المنصة الوطنية هذه القناة للتواصل وتحديث بيانات الجهات الحكومية وخدماتها المنشورة على المنصة أولا بأول.\",\"card_5_title\":\"تقارير صوت المستفيد\",\"card_5_description\":\"تقارير تتحدث عن كيفية مشاركة المستخدمين في صنع القرار لإنشاء خدمات جديدة والمشاركة في ايجاد الحلول ومعالجة التحديات داخل المنصة الوطنية الموحدة.\",\"card_6_title\":\"احصائيات ومؤشرات المنصة\",\"card_6_description\":\"توفر هذة الصفحة مقتطفات لإحصائيات القراء و المستخدمين لموقع المنصة الوطنية الموحدة والتي تم جمعها من أداة احصائيات قوقل.\",\"desc-eGovernment-portals\":\"يوفر هذا القسم لزوار المنصة الوطنية GOV.SA روابط مباشرة للبوابات الرسمية والمنصات الإلكترونية لدول مجلس التعاون الخليجي.\",\"customer_services_frequently_asked_questions_title\":\"الأسئلة الشائعة\",\"customer_services_frequently_asked_questions_description\":\"يوفر هذا القسم للمستخدمين إجابات على جميع الأسئلة الشائعة المتعلقة بالخدمات وما تحوي المنصة الوطنية الموحدة من معلومات وتفاصيل.\",\"customer_services_live_chat_title\":\"الشات المباشر\",\"customer_services_live_chat_description\":\"الدردشة الحية هي خدمة إلكترونية على مدار 24 ساعة يمكن للمستخدمين استخدامها عند مواجهة أي مشاكل داخل الموقع.\",\"customer_services_contact_us_title\":\"تواصل معنا\",\"customer_services_contact_us_description\":\"يتيح هذا القسم لزوار المنصة الوطنية الموحدة التواصل مع الجهات الحكومية ومسؤوليها عبر حساباتها على منصات التواصل الاجتماعي المتنوعة.\",\"customer_services_emergency_contact_numbers_title\":\"أرقام التواصل في حالات الطوارئ\",\"customer_services_emergency_contact_numbers_description\":\"توفر الصفحة قائمة بأرقام الاتصال في حالات الطوارئ في المملكة العربية السعودية.\",\"customer_services_report_corruption_title\":\"الإبلاغ عن فساد\",\"customer_services_report_corruption_description\":\"خدمة إلكترونية تقدمها هيئة الرقابة ومكافحة الفساد (نزاهة) تمكن المستفيد من تقديم بلاغ عن أي فساد إداري أو مالي في إحدى الجهات المشمولة باختصاصاتها.\",\"customer_services_digital_report_title\":\"بلاغ رقمي\",\"customer_services_digital_report_description\":\"خدمة تتيح للمستفيد فتح بلاغ بهدف التصعيد على الشكوى المقدمة على الجهة الحكومية مقدمة الخدمة، في حال تجاوز المدة الزمنية لمعالجة الشكوى أو في حال عدم رضا المستفيد.\",\"customer_services_live_sign_language_support_title\":\"دعم لغة الإشارة الحية\",\"customer_services_live_sign_language_support_description\":\"دعم لغة الإشارة الحية لمساعدة المستخدمين الذين يحتاجون إلى التواصل بهذه الطريقة.\",\"customer_services_social_media_title\":\"التواصل الاجتماعي\",\"customer_services_social_media_description\":\"يتيح هذا القسم لزوار المنصة الوطنية الموحدة التواصل مع الجهات الحكومية ومسؤوليها عبر حساباتها على منصات التواصل الاجتماعي المتنوعة.\",\"faq_service_availability\":\"تتوفر الخدمة\",\"faq_service_availability_value\":\"طوال الأسبوع\",\"faq_response_time\":\"مدة استلام الرد\",\"faq_response_time_value\":\"تواصل مباشر\",\"desc-digital_report\":\"خدمة تتيح للمستفيد فتح تذكرة من أجل تصعيد الشكوى المقدمة للجهة الحكومية المقدمة للخدمة في حالة تجاوز المدة الزمنية لمعالجة الشكوى أو عدم رضا المستفيد. أو طلب أي تطوير أو تحويل لأي خدمة حكومية من خدمة ورقية الى خدمة رقمية.\",\"digital_service_development_proposal_title\":\"اقتراح تطوير\",\"digital_service_development_proposal_description\":\"خدمة تتيح للمستفيد فتح بلاغ بهدف اقتراح تطوير لخدمة رقمية مقدمة من إحدى الجهات الحكومية.\",\"digital_transformation_request_title\":\"خدمة الإبلاغ عن خدمة ورقية\",\"digital_transformation_request_description\":\"خدمة تتيح للمستفيد فتح بلاغ لطلب تحول خدمة ورقية مُقدمة من إحدى الجهات الحكومية إلى خدمة رقمية.\",\"complaint_escalation_title\":\"تقديم شكوى\",\"complaint_escalation_description\":\"خدمة تتيح للمستفيد فتح بلاغ بهدف التصعيد على شكوى مقدمة على جهة حكومية، في حال تجاوز المدة الزمنية لمعالجة الشكوى أو في حال عدم رضا المستفيد.\",\"desc-social-media\":\"يتيح هذا القسم لزوار المنصة الوطنية Gov.sa التواصل مع الجهات الحكومية ومسؤوليها عبر حساباتها على منصات التواصل الاجتماعي المتنوعة.\",\"desc-participation-survey\":\"استبيان المشاركة في الفعاليات\",\"desc-contact_us\":\"نحن نعمل باستمرار لجعل تجربتك من خلال الخدمات الحكومية أسهل, سنقوم بالرد على رسالتكم خلال 24 ساعة\",\"firstName_label\":\"الاسم الأول\",\"firstName_placeholder\":\"أدخل الاسم الأول\",\"lastName_label\":\"الاسم الأخير\",\"lastName_placeholder\":\"أدخل الاسم الأخير\",\"mobileNumber_label\":\"رقم الجوال\",\"mobileNumber_placeholder\":\"أدخل رقم الجوال\",\"event_date\":\"تاريخ الفعالية\",\"email_label\":\"البريد الإلكتروني\",\"email_placeholder\":\"أدخل البريد الإلكتروني\",\"governmentAgency_label\":\"الجهة الحكومية\",\"governmentAgency_placeholder\":\"نص اختياري\",\"governmentAgency_option_ministry_interior\":\"وزارة الداخلية\",\"governmentAgency_option_ministry_health\":\"وزارة الصحة\",\"category_label\":\"الفئة\",\"category_placeholder\":\"اختر الفئة\",\"category_option_category1\":\"فئة 1\",\"category_option_category2\":\"فئة 2\",\"messageTitle_label\":\"عنوان الرسالة\",\"messageTitle_placeholder\":\"نص تلخيصي\",\"message_label\":\"الرسالة\",\"message_placeholder\":\"نص المدخل\",\"uploadedFile_label\":\"رفع الملف\",\"privacyConsent_label\":\"أوافق على سياسة الخصوصية\",\"validation_required\":\"هذا الحقل مطلوب\",\"validation_invalidMobileNumber\":\"رقم الجوال غير صالح\",\"validation_invalidEmail\":\"البريد الإلكتروني غير صالح\",\"validation_privacyConsent\":\"يجب الموافقة على سياسة الخصوصية\",\"validation_participate_event\":\"يرجى اختيار فعالية واحدة على الأقل\",\"buttons_submit\":\"إرسال\",\"messages_formSubmitted\":\"تم إرسال النموذج:\",\"messages_uploadedFile\":\"الملف المرفوع: {fileName}\",\"contact_with_ammer_title\":\"تواصل مع آمر\",\"whatsapp_channel_title\":\"قناة التواصل واتساب\",\"contact_us_button\":\"تواصل معنا\",\"contact_us_button_aria\":\"تواصل معنا عبر واتساب\",\"live_sign_language_title\":\"لغة الإشارة الحية\",\"report_corruption_nazaha_title\":\"بلاغ عن فساد إلى نزاهة\",\"emergency_numbers_title\":\"أرقام الطوارئ\",\"phone_label\":\"الهاتف\",\"working_hours_label\":\"أوقات العمل\",\"response_time_label\":\"وقت الاستجابة\",\"report_domestic_violence_label\":\"تبليغ عن حالة عنف أسري\",\"civil_defense_label\":\"الدفاع المدني\",\"police_label\":\"الشرطة\",\"ambulance_label\":\"الإسعاف\",\"support_live_sign_language_button\":\"دعم لغة الإشارة الحية\",\"support_live_sign_language_button_aria\":\"دعم لغة الإشارة الحية\",\"aria_visit_snapchat\":\"قم بزيارتنا على سناب شات\",\"aria_visit_instagram\":\"قم بزيارتنا على إنستغرام\",\"aria_visit_linkedin\":\"قم بزيارتنا على لينكدإن\",\"aria_visit_youtube\":\"قم بزيارتنا على يوتيوب\",\"response_time_value\":\"24 ساعة\",\"working_hours_value\":\"24/7 على مدار الساعة\",\"sub-title-experience\":\"تجارب مصممة بطابع شخصي يناسب احتياجك\",\"desc-experience\":\"انطلق عبر \\\"تجارب الحياة\\\" في رحلة حسب اختيارك حيث الهدف من كل رحلة هو تسهيل وتبسيط تقدّم المواطن والمقيم في كل خطوة من الرحلة وذلك عبر تزويده بالإجراءات والتنظيمات اللازمة وكذلك طُرق الحصول على المعلومات ذات الصلة من خلال الخدمات التي تقدمها الجهة الحكومية المختصة لضمان فاعليتها وكفاءتها. ستكون جميع الخطوات المطلوبة موضحة من بداية الرحلة وحتى نهايتها.\",\"more-details\":\"المزيد من التفاصيل\",\"stage_not_found\":\"لم يتم العثور على المرحلة\",\"stage_not_found_description\":\"المرحلة التي تبحث عنها غير موجودة.\",\"previous_stage\":\"المرحلة السابقة\",\"next_stage\":\"المرحلة القادمة\",\"none\":\"لا يوجد\",\"breadcrumb_title\":\"عنوان المرحلة الخاص بك هنا\",\"breadcrumb_description\":\"وصف المرحلة الخاص بك هنا.\",\"stage_not_available\":\"المرحلة غير متاحة\",\"common\":{\"buttons\":{\"prev\":\"السابق\",\"next\":\"التالي\",\"submit\":\"إرسال\"},\"validation\":{\"required\":\"هذا الحقل مطلوب\",\"invalidEmail\":\"البريد الإلكتروني غير صحيح\",\"invalidMobile\":\"رقم الجوال غير صحيح\",\"minLength\":\"يجب أن يكون {length} حرف على الأقل\",\"maxLength\":\"الحد الاعلى هو {length} حرفًا\",\"fileSize\":\"يجب ألا يتجاوز حجم الملف {size}\",\"fileType\":\"نوع ملف غير صالح\",\"invalidCredentials\":\"بيانات الدخول غير صحيحة\",\"invalidPhoneNumber\":\"الرجاء إدخال 8 أرقام بالضبط بعد '9665'.\",\"invalidIdNumber\":\"رقم الهوية يجب أن يحتوي على أرقام فقط\",\"idNumberLength\":\"رقم الهوية يجب أن يكون 10 أرقام\",\"idNumberStart\":\"رقم الهوية يجب أن يبدأ بـ 1 أو 2\"},\"attachments\":{\"button\":\"إرفاق ملف\",\"info\":\"يمكنك رفع ملفات PNG أو JPEG أو PDF  (الحد الأقصى 2 ميجابايت)\",\"maxSize\":\"الحد الأقصى {length} ميجابايت\",\"allowedTypes\":\"PNG, JPEG, PDF\"},\"form\":{\"labels\":{\"email\":\"البريد الإلكتروني\",\"mobile\":\"رقم الجوال\",\"city\":\"المدينة\",\"residence\":\"مكان الإقامة\",\"firstName\":\"الاسم الأول\",\"lastName\":\"اسم العائلة\",\"nationality\":\"الجنسية\",\"idNumber\":\"رقم الهوية\",\"attachments\":\"المرفقات\",\"password\":\"كلمة المرور\"},\"placeholders\":{\"email\":\"أدخل بريدك الإلكتروني\",\"nationality\":\"الجنسية\",\"mobile\":\"أدخل رقم الجوال\",\"city\":\"اختر المدينة\",\"residence\":\"اختر مكان الإقامة\"}},\"search\":\"بحث...\",\"noResults\":\"لا توجد نتائج\"},\"complaints\":{\"steps\":{\"review\":{\"label\":\"مراجعة الطلب\"},\"DigitalTransformationDetails\":{\"label\":\"تفاصيل الخدمة\"},\"newSuggetionDetails\":{\"label\":\"تفاصيل المقترح الجديد\"},\"beneficiary\":{\"label\":\"تفاصيل المستفيد\",\"description\":\"المعلومات الشخصية\"},\"complaintType\":{\"label\":\"نوع الشكوى\",\"description\":\"نوع وسبب الشكوى\"},\"platform\":{\"label\":\"تفاصيل المنصة\",\"description\":\"معلومات المنصة والخدمة\"},\"description\":{\"label\":\"الوصف\",\"description\":\"تفاصيل الشكوى والمرفقات\"}},\"form\":{\"titles\":{\"governmentDetails\":\"تفاصيل الجهة الحكومية\",\"platformDetails\":\"تفاصيل المنصة\",\"complaintDescription\":\"وصف الشكوى\"},\"labels\":{\"complaintType\":\"نوع الشكوى\",\"complaintReason\":\"سبب الشكوى\",\"governmentComplaintNumber\":\"رقم الشكوى الحكومية\",\"GAReportDate\":\"تاريخ الشكوى الحكومية\",\"isReportedToGA\":\"أعلم الجهة الحكومية\",\"complaintStatusInGA\":\"حالة الشكوى في الجهة الحكومية\",\"slaPassed\":\"مرور الموعد المحدد\",\"thresholdPassed\":\"مرور الحد المحدد\",\"reasonNotReported\":\"سبب عدم البلاغ\",\"governmentEntity\":\"الجهة الحكومية\",\"platform\":\"المنصة المستهدفة\",\"platformTooltip\":\"هذا الحقل لاختيار المنصة المستهدف إضافة الخدمة الورقية إليها بعد تحويلها إلى خدمة رقمية.\",\"problemType\":\"نوع المشكلة\",\"service\":\"الخدمة\",\"serviceChannel\":\"قناة الخدمة\",\"requestTitle\":\"عنوان الطلب\",\"description\":\"الوصف\",\"Write-problem\":\"اكتب المشكلة\"},\"placeholders\":{\"complaintType\":\"اختر نوع الشكوى\",\"complaintReason\":\"اختر سبب الشكوى\",\"governmentComplaintNumber\":\"أدخل رقم الشكوى\",\"GAReportDate\":\"اختر التاريخ\",\"governmentEntity\":\"اختر الجهة الحكومية\",\"platform\":\"اختر المنصة المستهدفة\",\"service\":\"عنوان الخدمة\",\"requestTitle\":\"أدخل عنوان الطلب\",\"description\":\"أدخل تفاصيل الطلب\",\"Write-problem\":\"اكتب المشكلة\"}},\"options\":{\"complaintTypes\":{\"type1\":\"عطل تقني\",\"type2\":\" سبب آخر\"},\"complaintReasons\":{\"technical\":{\"reason1\":\"شكوى تجاوزت المدة المحددة دون حل\",\"reason2\":\"لم يتم تحديد مدة لحل الشكوى\",\"reason3\":\"لم اتمكن من رفع شكوى\",\"reason4\":\"تم اغلاق الشكوى دون حل نهائي\"},\"procedural\":{\"reason1\":\"شكوى تجاوزت المدة المحددة دون حل\",\"reason2\":\"لم يتم تحديد مدة لحل الشكوى\",\"reason3\":\"لم اتمكن من رفع شكوى\"}},\"problemTypes\":{\"general\":\"مشكلة عامة\",\"specific\":\"خدمة محددة\"},\"serviceChannels\":{\"portal\":\"البوابة الإلكترونية\",\"app\":\"تطبيق الهاتف الذكي\",\"both\":\"كلا القناتين\"}},\"validation\":{\"governmentComplaintNumber\":{\"invalidFormat\":\"يجب أن يحتوي رقم الشكوى على أرقام وحروف لاتينية ورموز خاصة (- أو _) فقط.\"}}},\"desc_new_complaint\":\"خدمة تتيح للمستفيد فتح بلاغ بهدف التصعيد، على شكوى مقدمة على جهة حكومية، في حال تجاوز المدة الزمنية لمعالجة الشكوى أو في حال عدم رضا المستفيد\",\"desc_new_suggestion\":\"خدمة تتيح للمستفيد تقديم مقترحات تطويرية للخدمات المقدمة من الجهات الحكومية\",\"desc_user_complaints\":\"عرض جميع البلاغات والطلبات المقدمة\",\"desc_digital_transform_request\":\"خدمة تتيح للمستفيد فتح بلاغ لطلب تحويل خدمة ورقية مقدمة من إحدى الجهات الحكومية إلى خدمة رقمية\",\"user complaints\":\"بلاغاتي الرقمية\",\"new complaint\":\"شكوى جديدة\",\"realestate\":\"الإسكان والممتلكات\",\"new suggestion\":\"اقتراح جديد\",\"me\":\"أنا ؟\",\"gender_description\":\"يتم طلب هذة المعلومات لأغراض تحليلية وطنية في تحسين المنصة الوطنية الموحدة والتأكد من نسبة رضا / عدم رضا الجنسين،\",\"male\":\"ذكر\",\"female\":\"أنثى\",\"I'd-rather-not-say\":\"أفضّل عدم القول\",\"desc_benificaryReports\":\"تقارير مفصلة عن المستفيدين\",\"desc-surveys\":\"بيانات ونتائج الاستطلاعات\",\"beneficiary-voice-reports\":\"تقارير صوت المستفيد\",\"desc-beneficiary-voice-reports\":\"تقارير تتحدث عن كيفية مشاركة المستخدمين في صنع القرار لإنشاء خدمات جديدة والمشاركة في ايجاد الحلول ومعالجة التحديات داخل المنصة الوطنية الموحدة.\",\"download-the-report\":\"تحميل التقرير\",\"surveys\":\"الاستبيانات\",\"more_info\":\"لمزيد من المعلومات، يمكنك مراجعة\",\"electronic_participation_statement\":\"بيان المشاركة الإلكترونية\",\"and\":\"و\",\"subscription_rules\":\"قواعد الاشتراك\",\"desc-faqs\":\"يوفر هذا القسم لمستخدمي المنصة الوطنية GOV.sa إجابات على جميع الأسئلة الشائعة المتعلقة بالهوية الوطنية والهوية الرقمية، والملف الشخصي الوطني، وحماية المعلومات الشخصية، والبيانات المفتوحة، والمشاركة الإلكترونية، والأعمال، والمعلومات والاتصالات و الخدمات البريدية، والشؤون القانونية، والسلامة والبيئة، والتعليم والتدريب، وخدمات الصحة، والوثائق الشخصية، والثقافة والسياحية والترفيه، والمسائل العائلية وأحداث الحياة، والسكن والخدمات البلدية والمرافق، والعمل والتوظيف، وشؤون المقيمين والزوار ، والمركبات والنقل في المملكة.\",\"accordionItems\":{\"question1\":\"ما هي سياسة الإرجاع الخاصة بكم؟\",\"answer1\":\"تتيح لك سياسة الإرجاع لدينا إعادة المنتجات خلال 30 يومًا من الشراء. يرجى التأكد من أن العناصر في حالتها الأصلية.\",\"question2\":\"كيف يمكنني تتبع طلبي؟\",\"answer2\":\"يمكنك تتبع طلبك باستخدام رقم التتبع المرفق في رسالة التأكيد عبر البريد الإلكتروني. قم بزيارة صفحة التتبع الخاصة بنا وأدخل رقمك.\",\"question3\":\"هل تقدمون شحنًا دوليًا؟\",\"answer3\":\"نعم، نحن نقدم شحنًا دوليًا إلى دول مختارة. قد تختلف رسوم الشحن وأوقات التوصيل بناءً على الموقع.\"},\"forgot_password\":\"نسيت كلمة المرور؟\",\"auth\":{\"register\":{\"title\":\"استكمال بيانات التسجيل\",\"phone_info\":\"9665XXXXXXXX صيغة رقم الجوال الصحيحة\",\"success\":\"تم التسجيل بنجاح\",\"error\":\"حدث خطأ في التسجيل\"},\"otp\":{\"verify_title\":\"التحقق من رمز OTP\",\"enter_code_sent\":\"أدخل الرمز المرسل إلى {phone}\",\"input_label\":\"رمز التحقق\",\"time_remaining\":\"الوقت المتبقي:\",\"resend_code\":\"إعادة إرسال الرمز\",\"resend_code_aria\":\"إعادة إرسال رمز التحقق\",\"verify_button\":\"تحقق\",\"verify_button_aria\":\"تحقق من الرمز\",\"close_modal\":\"إغلاق النافذة\",\"validation\":{\"invalid_code\":\"الرمز غير صحيح\",\"expired_code\":\"انتهت صلاحية الرمز\"}},\"registration_success\":{\"success_icon_alt\":\"أيقونة النجاح\",\"message\":\"تم استكمال البيانات بنجاح\",\"cta_title\":\"الصفحة الرئيسية\",\"cta_aria\":\"زر الصفحة الرئيسية\"}},\"commentsSuggestions\":{\"title\":\"التعليقات والاقتراحات\",\"description-out\":\"لأي استفسارات أو ملاحظات، يرجى ملء المعلومات المطلوبة.\",\"description\":\"ماذا تريد أن تخبرنا ؟\",\"addComment\":\"اضافة تعليق\",\"name\":\"الاسم\",\"email\":\"ايميل\",\"message\":\"الرسالة\",\"cancel\":\"إلغاء\",\"submit\":\"إرسال\",\"validation\":{\"required\":\"هذه الخانة مطلوبه.\",\"invalidEmail\":\"يرجى إدخال بريد إلكتروني صالح.\"},\"success\":{\"title\":\"تم إرسال التعليق بنجاح\",\"desc\":\"شكرًا لتعليقك ، رأيك يساهم معنا بالتحسين.\"}},\"pagination\":{\"showing_results\":\"عرض النتائج {startItem}-{endItem} من {totalItems} نتيجة\",\"dots\":\"نقاط\",\"prev\":\"الصفحة السابقة\",\"next\":\"الصفحة التالية\",\"first\":\"الصفحة الأولى\",\"last\":\"الصفحة الأخيرة\"},\"page_rating\":{\"positive_options\":{\"p1\":\"المحتوى مناسب\",\"p2\":\"المحتوى دقيق والكتابة جيدة\",\"p3\":\"التصميم ساعد في تسهيل القراءة\",\"p4\":\"سبب اخر\"},\"negative_options\":{\"n1\":\"المحتوى غير مناسب\",\"n2\":\"المحتوي غير دقيق\",\"n3\":\"المحتوى طويل جدا\",\"n4\":\"سبب اخر\"},\"success\":{\"title\":\"تم إرسال التقييم بنجاح\",\"desc\":\"شكرًا لتقيميك ، رأيك يساهم معنا بالتحسين.\",\"subDesc\":\"يمكنك الاطلاع على احصائيات مؤشر رضا الزوار من {here}\"}},\"here\":\"هنا\",\"month\":\"شهر\",\"year\":\"سنة\",\"add_event\":\"إضافة فعالية\",\"event_details\":{\"title\":\"إضافة فعالية\",\"eventName\":\"اسم الفعالية\",\"eventLocation\":\"مكان الفعالية\",\"eventDate\":\"تاريخ الفعالية\",\"country\":\"الدولة\",\"eventScope\":\"نطاق الفعالية\",\"placeholders\":{\"eventName\":\"اكتب اسم الفعالية\",\"country\":\"اختر الدولة\",\"eventLocation\":\"اكتب مكان الفعالية\",\"eventDate\":\"اختر تاريخ الفعالية\",\"eventScope\":\"نطاق الفعالية\"},\"validation\":{\"required\":\"هذا الحقل مطلوب\",\"invalidEm